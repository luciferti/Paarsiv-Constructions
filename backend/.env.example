# --- Required ---

# Postgres in production (Render injects this automatically via render.yaml).
# SQLite for local dev: sqlite:///./demo.db
DATABASE_URL=sqlite:///./demo.db

# Long random string. Render generates one automatically via render.yaml.
JWT_SECRET_KEY=change-me

# Never true outside local preview — bypasses all authentication.
DEMO_MODE=false

# Comma-separated browser origins allowed to call this API.
FRONTEND_ORIGIN=http://localhost:3000

# --- Optional integrations (features degrade gracefully without them) ---

# Unlocks GPT-backed AI summaries + free-form assistant chat.
# OPENAI_API_KEY=

# Unlocks real outbound WhatsApp sending.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=+14155238886

# Org the inbound WhatsApp bot answers for (id from the organizations table).
# WHATSAPP_DEFAULT_ORG_ID=
